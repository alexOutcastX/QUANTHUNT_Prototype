# Copy to /opt/quanthunt/.env on the VM (never commit real values).
# Owner passcode — required to use broker features (holdings are private).
APP_PASSWORD=
# Optional: explicit cookie-signing secret (else derived from APP_PASSWORD).
APP_SECRET=
# Optional: comma-separated allowed cross-origin callers (default same-origin).
CORS_ORIGINS=
# Terminal AI relationship graphs (any company).
ANTHROPIC_API_KEY=
GRAPH_AI_MODEL=claude-sonnet-5
# Fundamentals (optional licensed source).
EODHD_API_KEY=
# BYOB Zerodha Kite (read-only holdings sync).
KITE_API_KEY=
KITE_API_SECRET=
